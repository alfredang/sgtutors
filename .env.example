# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5433/sgtutors

# Server
PORT=4000
APP_URL=http://localhost:5173
JWT_SECRET=change-me-tutor-secret
ADMIN_JWT_SECRET=change-me-admin-secret
IP_HASH_SALT=change-me-salt
UPLOADS_DIR=./uploads

# Stripe (test mode)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Cloudflare Turnstile (defaults are Cloudflare's always-pass test keys)
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
VITE_TURNSTILE_SITE_KEY=1x00000000000000000000BB

# Cloudflare R2 — profile photo storage (no files on the VPS).
# Create an R2 bucket, an API token with Object Read & Write, and enable
# public access (r2.dev subdomain or custom domain) for R2_PUBLIC_BASE_URL.
# When unset, photos fall back to local disk (dev only).
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=

# Google Drive — verification document archive (no files on the VPS).
# 1. Create a Google Cloud service account + JSON key.
# 2. Share a Drive folder with the service account email (Editor).
# 3. Set the folder ID below; the app creates one subfolder per tutor
#    (named with the tutor's full name) holding NRIC, cert and CV.
# When unset, documents fall back to local disk (dev only).
GDRIVE_PARENT_FOLDER_ID=
GDRIVE_SERVICE_ACCOUNT_JSON=./gdrive-service-account.json
# Verification documents are erased this many months after verification
DOCS_RETENTION_MONTHS=3

# Claude Agent SDK — AI interview
# Preferred: subscription OAuth token from `claude setup-token`
CLAUDE_CODE_OAUTH_TOKEN=
# Fallback: pay-per-use API key
ANTHROPIC_API_KEY=
# Optional model override (defaults to the SDK default model)
INTERVIEW_MODEL=

# Email (SMTP). With EMAIL_DEV_MODE=true, emails are logged to console instead.
EMAIL_DEV_MODE=true
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@sgtutors.local
ADMIN_EMAIL=admin@sgtutors.local

# Seeded admin account
ADMIN_PASSWORD=admin123
